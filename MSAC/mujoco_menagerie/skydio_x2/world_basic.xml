<mujoco model="Skydio X2 Basic Training">
  <include file="x2.xml"/>

  <statistic center="0 0 0.1" extent="10" meansize=".05"/>
  
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3"/>
  </visual>

  <asset>
    <texture type="2d" name="ground" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" width="300" height="300"/>
    <material name="ground_mat" texture="ground" texrepeat="5 5"/>
    <material name="goal_mat" rgba="0.2 0.8 0.2 0.5"/>
  </asset>

  <worldbody>
    <light pos="0 0 5" dir="0 0 -1" directional="true"/>
    
    <!-- Sàn nhà -->
    <geom name="floor" size="20 20 0.1" type="plane" material="ground_mat"/>
    
    <!-- Define 4 sites with unique names -->
    <site name="waypoint0" pos="4.0 0.0 2.0" size="0.2" rgba="0 1 0 0.8" type="sphere"/>
    <site name="waypoint1" pos="-4.0 4.0 1.0" size="0.2" rgba="1 0 0 0.3" type="sphere"/>
    <site name="waypoint2" pos="0.0 -4.0 3.0" size="0.2" rgba="1 0 0 0.3" type="sphere"/>
    <site name="waypoint3" pos="0.0 0.0 1.5" size="0.2" rgba="1 0 0 0.3" type="sphere"/>
  </worldbody>
</mujoco>